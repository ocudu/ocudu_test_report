type: object
required:
  - features
properties:
  features:
    type: array
    minItems: 1
    items:
      $ref: '#/$defs/feature'
$defs:
  feature:
    type: object
    required:
      - id
      - source
      - scope
      - description
      - release
      - primary_test_type
      - comment
    properties:
      id:
        type: string
      source:
        type: string
        enum:
          - "ATIS-MVP"
          - "Customer defined"
          - "SRS defined"
      scope:
        type: string
        enum:
          - "CU/DU"
          - "Unspecified"
          - "Entire RAN Product"
          - "Platform/deployment/auxiliary component"
      description:
        type: string
      release:
        type: string
        enum:
          - "v26.04"
          - "26.10 (v2.1)"
          - "27.04 (v2.2)"
          - "27.10 (v2.3)"
          - "28.04 (v2.4)"
          - "28.10 (v2.5)"
          - "unspecified"
      primary_test_type:
        type: array
        items:
          type: string
          enum: ["unit", "integration", "e2e"]
      comment:
        type: string

