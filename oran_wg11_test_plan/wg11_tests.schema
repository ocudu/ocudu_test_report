$schema: "http://json-schema.org/draft-07/schema#"
title: O-RAN WG11 Security Test Plan
description: O-RAN WG11 security test cases
type: object
required:
  - tests
additionalProperties: false
properties:
  tests:
    type: array
    minItems: 1
    items:
      type: object
      required:
        - test_id
        - description
        - category
        - scope
        - comment
      additionalProperties: false
      properties:
        test_id:
          type: string
          description: Test case identifier matching the section number in the WG11 spec
          pattern: "^[A-Za-z_0-9]+(\\.[0-9]+)*$"
        description:
          type: string
          description: Human-readable test case description
          minLength: 1
        category:
          type: string
          description: Section / category of the test as defined in the WG11 spec
          enum:
            - "Security Protocol & APIs Validation"
            - "Common Network Security Tests for O-RAN components"
            - "System security evaluation for O-RAN component"
            - "Software security evaluation for O-RAN components"
            - "Security tests of O-RAN interfaces - FH"
            - "Security tests of O-RAN interfaces - Y1"
            - "Security tests of O-RAN interfaces - O1"
            - "Security tests of O-RAN interfaces - O2"
            - "Security tests of O-RAN interfaces - E2"
            - "Security tests of O-RAN interfaces - A1"
            - "Security tests of O-RAN interfaces - R1"
            - "Security test of O-RU"
            - "Security test of Near-RT RIC"
            - "Security test of xApps"
            - "Security test of Non-RT RIC"
            - "Security test of rApps"
            - "Security test of SMO"
            - "Security test of O-Cloud"
            - "Security test of VNF/CNF"
            - "Security tests of Common Application Lifecycle Management"
            - "Security test of O-CU-CP"
            - "Security test of O-CU-UP"
            - "Security test of O-DU"
            - "End-to-End security test cases - 3GPP SCAS NR"
            - "End-to-End security test cases - 3GPP SCAS LTE"
            - "End-to-End security test cases - DoS, fuzzing and blind exploitation"
            - "Security test of Shared O-RU"
        scope:
          type: string
          description: Scope of the test, as defined for OCUDU features
          enum:
            - "CU/DU"
            - "Entire RAN/platform/deployment/auxiliary component"
        comment:
          type: string
          description: Free-form comment for this test case
